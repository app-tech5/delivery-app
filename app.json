{
  "expo": {
    "name": "Good Food Driver",
    "icon": "./assets/images/logo512.png",
    "splash": {
      "image": "./assets/images/splash-screen.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "version": "1.1.0",
    "slug": "good-food-driver",
    "ios": {
      "bundleIdentifier": "com.goodfood.driver",
      "buildNumber": "1.1.0"
    },
    "android": {
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_LOCATION"
      ],
      "package": "com.goodfood.driver",
      "versionCode": 2
    },
    "plugins": [
      "expo-font",
      "expo-localization",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Good Food Driver utilise votre position pour les livraisons.",
          "locationAlwaysAndWhenInUsePermission": "Good Food Driver utilise votre position pour les livraisons, y compris en arrière-plan.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      "@maplibre/maplibre-react-native"
    ],
    "extra": {
      "eas": {
        "projectId": "8aa2a030-0463-4d52-96c8-5b8d09b2e428"
      }
    }
  }
}
